# Server
PORT=3000
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://localhost:27017/chatbot

# OpenAI
OPENAI_API_KEY=sk-your-openai-api-key
# Realtime voice (optional defaults)
# REALTIME_MODEL=gpt-realtime
# REALTIME_DEFAULT_VOICE=shimmer
# REALTIME_ENABLE_INPUT_TRANSCRIPTION=1
# REALTIME_INPUT_TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe

# SMTP email (optional, for sending leads)
# SMTP_HOST=smtp.zoho.com
# SMTP_PORT=587
# SMTP_USER=hello@unidevsolutions.in
# SMTP_PASS=your-app-password
# EMAIL_FROM=hello@unidevsolutions.in
# EMAIL_TO=hello@unidevsolutions.in
# For Zoho: use an App Password (not your login password) if 2FA is on.
# Create at: https://accounts.zoho.com/home#security/security_pwd

# Rate limit (optional)
# RATE_LIMIT_WINDOW_MS=60000
# RATE_LIMIT_MAX=30

# Log all request/response data for testing (optional)
# LOG_TEST_DATA=1

# WhatsApp Web (optional)
# WHATSAPP_ENABLED=1
# CHROME_PATH=/usr/bin/chromium-browser   # Linux example; Mac uses Chrome.app by default
# On-demand login: POST /api/whatsapp/login (returns qrDataUrl). POST { "force": true } to reset QR/session.
# GET /api/whatsapp/health — whatsappReady. POST /api/whatsapp/send-message — { phone, message }
